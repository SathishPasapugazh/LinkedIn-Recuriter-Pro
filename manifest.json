{
  "manifest_version": 3,
  "name": "PDF Viewer & Annotator",
  "version": "1.0.0",
  "description": "A powerful PDF viewer with annotation capabilities (text, highlight, draw) built with pdf.js.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://generativelanguage.googleapis.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ]
}
